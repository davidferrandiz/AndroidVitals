default_platform(:android)

platform :android do

  lane :test do
    gradle(task: "test")
  end

  # Lane: upload_only
  # El workflow de GitHub Actions ya ha compilado y firmado el AAB.
  # Este lane solo sube el binario existente a Play Console.
  # No recompila ni toca el versionCode — eso lo gestiona el workflow.
  lane :upload_only do
    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      release_status: "draft"
    )
  end

  # Lane: beta (uso local)
  # Para subir desde tu Mac sin pasar por CI.
  # Aquí sí compilamos porque no tenemos el paso previo del workflow.
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release"
    )
    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      release_status: "draft"
    )
  end

  # Lane: promote_to_alpha
  # Promueve la release de internal → alpha sin recompilar.
  # Ejecución manual: bundle exec fastlane promote_to_alpha
  lane :promote_to_alpha do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "alpha"
    )
  end

end
