# Gemfile — gestor de dependencias Ruby para este proyecto
#
# Fastlane es una herramienta Ruby, por lo que necesita Bundler (el npm de Ruby)
# para gestionar sus dependencias y garantizar que todos los entornos
# (tu Mac, el runner de GitHub Actions) usen exactamente la misma versión.
#
# Uso:
#   bundle install       → instala fastlane en local
#   bundle exec fastlane → ejecuta fastlane con la versión correcta
#
# El Gemfile.lock que genera Bundler SÍ debe subirse al repo,
# así GitHub Actions usa la misma versión que tu máquina.

source "https://rubygems.org"

gem "fastlane"
